datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String         @id @default(cuid())
  userId             String         @unique @db.VarChar(50)
  email              String?        @unique @db.VarChar(255)
  password           String         @db.VarChar(255)
  name               String         @db.VarChar(100)
  createdAt          DateTime       @default(now())
  transactions       Transaction[]
  debts              Debt[]
  budgets            Budget[]
  categories         Category[]
  monthlyBills       MonthlyBill[]
  groupMemberships   GroupMember[]
  splitRequestsFrom  SplitRequest[] @relation("SplitFrom")
  splitRequestsTo    SplitRequest[] @relation("SplitTo")
  savingsGoals       SavingsGoal[]
}

model Group {
  id        String        @id @default(cuid())
  name      String        @db.VarChar(100)
  joinCode  String        @unique @db.VarChar(10)
  members   GroupMember[]
  createdAt DateTime      @default(now())
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("MEMBER") // "OWNER" | "MEMBER"
  group    Group    @relation(fields: [groupId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model SplitRequest {
  id            String    @id @default(cuid())
  fromUserId    String
  toUserId      String
  amount        Decimal   @db.Decimal(10, 2)
  description   String    @db.VarChar(255)
  status        String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  transactionId String?
  fromUser      User      @relation("SplitFrom", fields: [fromUserId], references: [id])
  toUser        User      @relation("SplitTo", fields: [toUserId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([fromUserId])
  @@index([toUserId])
}

model Category {
  id           String        @id @default(cuid())
  name         String        @db.VarChar(100)
  type         String        // "INCOME" | "EXPENSE"
  icon         String?       @db.VarChar(50)
  color        String?       @db.VarChar(20)
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  budgets      Budget[]
  monthlyBills MonthlyBill[]

  @@index([userId])
}

model Transaction {
  id              String    @id @default(cuid())
  type            String    // "INCOME" | "EXPENSE"
  amount          Decimal   @db.Decimal(10, 2)
  description     String    @db.VarChar(255)
  date            DateTime
  note            String?   @db.Text
  paidTo          String?   @db.VarChar(255)
  splitWith       String?   @db.VarChar(255)
  splitWithUserId String?   @db.VarChar(255)
  splitAmount     Decimal?  @db.Decimal(10, 2)
  splitStatus     String?   // "PENDING" | "CONFIRMED"
  categoryId      String
  userId          String
  category        Category  @relation(fields: [categoryId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([date])
}

model Debt {
  id              String        @id @default(cuid())
  name            String        @db.VarChar(255)
  creditor        String        @db.VarChar(255)
  totalAmount     Decimal       @db.Decimal(10, 2)
  remainingAmount Decimal       @db.Decimal(10, 2)
  interestRate    Decimal       @db.Decimal(5, 2)
  monthlyPayment  Decimal       @db.Decimal(10, 2)
  dueDate         DateTime?
  status          String        @default("ACTIVE")
  type            String
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  payments        DebtPayment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
}

model DebtPayment {
  id          String   @id @default(cuid())
  debtId      String
  amount      Decimal  @db.Decimal(10, 2)
  paymentDate DateTime
  note        String?  @db.VarChar(255)
  debt        Debt     @relation(fields: [debtId], references: [id])
  createdAt   DateTime @default(now())

  @@index([debtId])
}

model Budget {
  id         String   @id @default(cuid())
  categoryId String
  amount     Decimal  @db.Decimal(10, 2)
  month      String   @db.VarChar(7)
  userId     String
  category   Category @relation(fields: [categoryId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([categoryId, month, userId])
  @@index([userId])
}

model MonthlyBill {
  id         String        @id @default(cuid())
  name       String        @db.VarChar(255)
  amount     Decimal       @db.Decimal(10, 2)
  isVariable Boolean       @default(false)
  frequency  String        @default("MONTHLY") // "MONTHLY" | "WEEKLY"
  dueDay     Int
  paidTo     String?       @db.VarChar(255)
  note       String?       @db.VarChar(255)
  categoryId String
  userId     String
  category   Category      @relation(fields: [categoryId], references: [id])
  user       User          @relation(fields: [userId], references: [id])
  payments   BillPayment[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([userId])
  @@index([categoryId])
}

model BillPayment {
  id        String      @id @default(cuid())
  billId    String
  month     String      @db.VarChar(7)
  amount    Decimal     @db.Decimal(10, 2)
  status    String      // "PAID" | "WAITING_REFUND"
  paidDate  DateTime
  note      String?     @db.VarChar(255)
  bill      MonthlyBill @relation(fields: [billId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([billId, month])
  @@index([billId])
}

model SavingsGoal {
  id           String    @id @default(cuid())
  name         String    @db.VarChar(255)
  emoji        String    @default("🎯") @db.VarChar(10)
  targetAmount Decimal   @db.Decimal(10, 2)
  savedAmount  Decimal   @default(0) @db.Decimal(10, 2)
  deadline     DateTime?
  weeklyTarget Decimal?  @db.Decimal(10, 2)
  color        String    @default("#FF5B36") @db.VarChar(20)
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}
